# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000

# ─── Database (Supabase Postgres — use the pooled connection URL) ─
# Settings → Database → Connection string → "Transaction" pooler (port 6543)
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Replace <password> with the real password — do NOT keep the [] brackets from Supabase's template.
# Append ?sslmode=require so the Postgres protocol layer also enforces TLS.
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# ─── Postgres TLS hardening (recommended for production) ─────────
# Path to a PEM file containing the Supabase pooler root CA. Download from
# Supabase → Settings → Database → SSL configuration → Download cert.
# When set, the connection verifies the server's cert chain against this CA
# (strongly recommended for production). When unset, the connection is
# still TLS-encrypted but the chain isn't verified — fine for local dev.
DATABASE_CA_CERT_PATH=
# Alternatively, set this to "true" to verify against Node's default CA
# bundle (works for some hosted Postgres setups; usually fails for
# Supabase pooler — prefer DATABASE_CA_CERT_PATH).
DATABASE_SSL_REJECT_UNAUTHORIZED=

# ─── Supabase Auth (server — NEVER commit real values) ───────────
# Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Settings → API → Project API keys → service_role (server-only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role_key...

# ─── Supabase (browser — exposed to client via Vite) ─────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Settings → API → Project API keys → anon / public
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...anon_key...

# ─── Stripe ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── AI providers ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# OpenRouter powers 4 of the 5 citation platforms (Claude, Gemini,
# Perplexity, DeepSeek). ChatGPT citations still use OPENAI_API_KEY.
# Without this key those 4 platforms are skipped gracefully.
OPENROUTER_API_KEY=sk-or-...

# ─── Email ───────────────────────────────────────────────────────
# Password reset is handled by Supabase Auth (magic link).
# Weekly AI visibility reports are sent via Resend — free tier: 3,000 emails/day.
# Leave blank to disable the weekly report cron entirely.
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=VentureCite <reports@venturecite.app>
# Optional cron override (default: Sunday 8:00 AM UTC)
WEEKLY_REPORT_CRON=0 8 * * 0

# ─── Buffer Social Publishing ────────────────────────────────────
# Create an app at https://buffer.com/developers/apps
BUFFER_CLIENT_ID=
BUFFER_CLIENT_SECRET=
BUFFER_REDIRECT_URI=http://localhost:5000/api/auth/buffer/callback
# Required when BUFFER_CLIENT_ID is set. Encrypts the OAuth access token
# at rest in the database (AES-256-GCM). Generate with:
#   openssl rand -base64 32
# Rotating this key invalidates every stored Buffer token (users will
# need to re-connect Buffer). NEVER commit a real value.
BUFFER_ENCRYPTION_KEY=

# ─── Shopify webhooks (optional) ─────────────────────────────────
# When unset, the Shopify webhook endpoint rejects every request
# (fail closed). Set this to enable purchase-event ingestion from
# Shopify stores. From Shopify Admin → Settings → Notifications →
# Webhooks, copy the "Webhook signing secret".
SHOPIFY_WEBHOOK_SECRET=

# ─── Email unsubscribe HMAC secret ───────────────────────────────
# Signs the one-click unsubscribe tokens embedded in transactional
# emails (List-Unsubscribe header). Generate with:
#   openssl rand -base64 32
# Falls back to SESSION_SECRET if unset, but a dedicated key is safer.
EMAIL_UNSUBSCRIBE_SECRET=

# ─── Resend bounce / complaint webhook ───────────────────────────
# Configure a webhook in the Resend dashboard pointing at:
#   https://app.venturecite.app/api/webhooks/resend
# subscribed to email.bounced, email.complained, email.delivered.
# Copy the "Signing secret" (starts with "whsec_") here. When unset,
# the endpoint rejects all requests so a missing webhook integration
# can't be silently exploited.
RESEND_WEBHOOK_SECRET=

# Optional: pin the Stripe API version explicitly. When unset, the
# server falls back to a hardcoded version (see server/stripeClient.ts).
STRIPE_API_VERSION=

# ─── Observability (Sentry + log level) ──────────────────────────
# Both are optional — if SENTRY_DSN is unset, error capture is a no-op.
# https://sentry.io → Settings → Client Keys (DSN)
SENTRY_DSN=
# Browser-exposed Sentry DSN. Often the same project, sometimes a separate
# frontend project. Vite ships VITE_* values to the client bundle.
VITE_SENTRY_DSN=
# Tag events with environment (defaults to NODE_ENV if unset).
SENTRY_ENVIRONMENT=
# pino log level — fatal | error | warn | info | debug | trace | silent
# Defaults: debug (dev), info (prod).
LOG_LEVEL=
