# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000

# ─── Database (Supabase Postgres — use the pooled connection URL) ─
# Settings → Database → Connection string → "Transaction" pooler (port 6543)
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Replace <password> with the real password — do NOT keep the [] brackets from Supabase's template.
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── Supabase Auth (server — NEVER commit real values) ───────────
# Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Settings → API → Project API keys → service_role (server-only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role_key...

# ─── Supabase (browser — exposed to client via Vite) ─────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Settings → API → Project API keys → anon / public
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...anon_key...

# ─── Stripe ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── AI providers ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# OpenRouter powers 4 of the 5 citation platforms (Claude, Gemini,
# Perplexity, DeepSeek). ChatGPT citations still use OPENAI_API_KEY.
# Without this key those 4 platforms are skipped gracefully.
OPENROUTER_API_KEY=sk-or-...

# ─── Email ───────────────────────────────────────────────────────
# Password reset is handled by Supabase Auth (magic link).
# Weekly AI visibility reports are sent via Resend — free tier: 3,000 emails/day.
# Leave blank to disable the weekly report cron entirely.
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=VentureCite <reports@venturecite.app>
# Optional cron override (default: Sunday 8:00 AM UTC)
WEEKLY_REPORT_CRON=0 8 * * 0

# ─── Buffer Social Publishing ────────────────────────────────────
# Create an app at https://buffer.com/developers/apps
BUFFER_CLIENT_ID=
BUFFER_CLIENT_SECRET=
BUFFER_REDIRECT_URI=http://localhost:5000/api/auth/buffer/callback
