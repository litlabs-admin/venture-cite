{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "api/_bundle.js"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/webhooks/(.*)", "destination": "/api/index" },
    {
      "source": "/((?!api|webhooks|health|assets|fonts|favicon\\.ico|robots\\.txt|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    { "path": "/api/cron/daily-orchestrator", "schedule": "0 6 * * *" },
    { "path": "/api/cron/fact-scrape-backstop", "schedule": "*/5 * * * *" }
  ]
}
